@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .

<https://github.com/creesullivan/cephean/autotune>
	a lv2:Plugin , lv2:PitchPlugin ;
	
	lv2:extensionData <http://lv2plug.in/ns/ext/state#interface> ;

    lv2:optionalFeature <http://lv2plug.in/ns/lv2core#hardRTCapable> ,
                        <http://lv2plug.in/ns/ext/buf-size#boundedBlockLength> ;

    lv2:requiredFeature <http://lv2plug.in/ns/ext/options#options> ,
                        <http://lv2plug.in/ns/ext/urid#map> ;
	
	doap:name "Cephean AutoTune";
	doap:license "ISC";
	doap:maintainer [
        foaf:name "cephean" ;
    ] ;
	
	rdfs:comment """
Cephean basic monophonic autotune
""" ;
	
	lv2:minorVersion 1 ;
	lv2:microVersion 0 ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 0 ;
		lv2:symbol "fundamental" ;
		lv2:name "Fundamental" ;
		lv2:default 0 ;
		lv2:minimum 0 ;
		lv2:maximum 11 ;
		lv2:portProperty lv2:integer, lv2:enumeration;
		lv2:scalePoint [rdfs:label "C"; rdf:value 0];
		lv2:scalePoint [rdfs:label "Db"; rdf:value 1];
		lv2:scalePoint [rdfs:label "D"; rdf:value 2];
		lv2:scalePoint [rdfs:label "Eb"; rdf:value 3];
		lv2:scalePoint [rdfs:label "E"; rdf:value 4];
		lv2:scalePoint [rdfs:label "F"; rdf:value 5];
		lv2:scalePoint [rdfs:label "Gb"; rdf:value 6];
		lv2:scalePoint [rdfs:label "G"; rdf:value 7];
		lv2:scalePoint [rdfs:label "Ab"; rdf:value 8];
		lv2:scalePoint [rdfs:label "A"; rdf:value 9];
		lv2:scalePoint [rdfs:label "Bb"; rdf:value 10];
		lv2:scalePoint [rdfs:label "B"; rdf:value 11]
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 1 ;
		lv2:symbol "mode" ;
		lv2:name "Mode" ;
		lv2:default 0 ;
		lv2:minimum 0 ;
		lv2:maximum 8 ;
		lv2:portProperty lv2:integer, lv2:enumeration;
		lv2:scalePoint [rdfs:label "chromatic"; rdf:value 0];
		lv2:scalePoint [rdfs:label "major"; rdf:value 1];
		lv2:scalePoint [rdfs:label "minor"; rdf:value 2];
		lv2:scalePoint [rdfs:label "harmonic"; rdf:value 3];
		lv2:scalePoint [rdfs:label "melodic"; rdf:value 4];
		lv2:scalePoint [rdfs:label "dorian"; rdf:value 5];
		lv2:scalePoint [rdfs:label "phrygian"; rdf:value 6];
		lv2:scalePoint [rdfs:label "lydian"; rdf:value 7];
		lv2:scalePoint [rdfs:label "mixolydian"; rdf:value 8]
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 2 ;
		lv2:symbol "tuning" ;
		lv2:name "Tuning" ;
		lv2:default 440.0 ;
		lv2:minimum 400.0 ;
		lv2:maximum 500.0 ;
		units:unit units:hz 
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 3 ;
		lv2:symbol "pitch1" ;
		lv2:name "Pitch1" ;
		lv2:default 52 ;
		lv2:minimum 48 ;
		lv2:maximum 100 ;
		lv2:portProperty lv2:integer;
		units:unit units:note 
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 4 ;
		lv2:symbol "pitch2" ;
		lv2:name "Pitch2" ;
		lv2:default 81 ;
		lv2:minimum 48 ;
		lv2:maximum 100 ;
		lv2:portProperty lv2:integer;
		units:unit units:note 
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 5 ;
		lv2:symbol "smooth" ;
		lv2:name "Smooth" ;
		lv2:default 50.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 100.0 ;
		units:unit units:pc
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:AudioPort ;
		lv2:index 6 ;
		lv2:symbol "in" ;
		lv2:name "In"
	] ;
	
	lv2:port [
		a lv2:OutputPort , lv2:AudioPort ;
		lv2:index 7 ;
		lv2:symbol "out" ;
		lv2:name "Out"
	] .
