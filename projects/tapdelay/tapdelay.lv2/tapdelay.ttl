@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .
@prefix mod: <http://moddevices.com/ns/mod#> .

<https://github.com/creesullivan/cephean/tapdelay>
	a lv2:Plugin , lv2:DelayPlugin ;
	
	lv2:extensionData <http://lv2plug.in/ns/ext/state#interface> ;

    lv2:optionalFeature <http://lv2plug.in/ns/lv2core#hardRTCapable> ,
                        <http://lv2plug.in/ns/ext/buf-size#boundedBlockLength> ;

    lv2:requiredFeature <http://lv2plug.in/ns/ext/options#options> ,
                        <http://lv2plug.in/ns/ext/urid#map> ;
	
	doap:name "Cephean Tap Delay";
	doap:license "ISC";
	doap:maintainer [
        foaf:name "cephean" ;
    ] ;
	
	rdfs:comment """
Cephean basic delay with built-in tap tempo compatible with MOD Dwarf
""" ;
	
	lv2:minorVersion 1 ;
	lv2:microVersion 0 ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 0 ;
		lv2:symbol "mode" ;
		lv2:name "Mode" ;
		lv2:default 0 ;
		lv2:minimum 0 ;
		lv2:maximum 5 ;
		lv2:portProperty lv2:integer, lv2:enumeration;
		lv2:scalePoint [rdfs:label "1"; rdf:value 0];
		lv2:scalePoint [rdfs:label "3/4"; rdf:value 1];
		lv2:scalePoint [rdfs:label "2/3"; rdf:value 2];
		lv2:scalePoint [rdfs:label "1/2"; rdf:value 3];
		lv2:scalePoint [rdfs:label "1/3"; rdf:value 4];
		lv2:scalePoint [rdfs:label "1/4"; rdf:value 5]
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 1 ;
		lv2:symbol "tempo" ;
		lv2:name "Tempo" ;
		lv2:default 120.0 ;
		lv2:minimum 45.0 ;
		lv2:maximum 240.0 ;
		units:unit units:bpm ;
		lv2:portProperty  mod:tapTempo, mod:tempoRelatedDynamicScalePoints
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 2 ;
		lv2:symbol "feedback" ;
		lv2:name "Feedback" ;
		lv2:default 50.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 100.0 ;
		units:unit units:pc
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 3 ;
		lv2:symbol "color" ;
		lv2:name "Color" ;
		lv2:default 100.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 100.0 ;
		units:unit units:pc
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 4 ;
		lv2:symbol "rolloff" ;
		lv2:name "Rolloff" ;
		lv2:default 0.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 100.0 ;
		units:unit units:pc
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 5 ;
		lv2:symbol "dry" ;
		lv2:name "Dry" ;
		lv2:default 50.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 100.0 ;
		units:unit units:pc
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 6 ;
		lv2:symbol "wet" ;
		lv2:name "Wet" ;
		lv2:default 50.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 100.0 ;
		units:unit units:pc
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:AudioPort ;
		lv2:index 7 ;
		lv2:symbol "in" ;
		lv2:name "In"
	] ;
	
	lv2:port [
		a lv2:OutputPort , lv2:AudioPort ;
		lv2:index 8 ;
		lv2:symbol "out" ;
		lv2:name "Out"
	] .
