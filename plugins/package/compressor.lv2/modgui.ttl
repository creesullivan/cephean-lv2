@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://github.com/creesullivan/cephean/compressor>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-cephean-compressor.html> ;
        modgui:stylesheet <modgui/stylesheet-cephean-compressor.css> ;
        modgui:screenshot <modgui/screenshot-cephean-compressor.png> ;
        modgui:thumbnail <modgui/thumbnail-cephean-compressor.png> ;
        modgui:brand "cephean" ;
        modgui:label "COMPRESSOR" ;
        modgui:model "boxy" ;
        modgui:panel "6-knobs" ;
        modgui:color "darkblue" ;
        modgui:knob "black" ;
        modgui:port [
            lv2:index 0 ;
            lv2:symbol "tone" ;
            lv2:name "Tone" ;
        ] , [
            lv2:index 1 ;
            lv2:symbol "dry" ;
            lv2:name "Dry" ;
        ] , [
            lv2:index 2 ;
            lv2:symbol "wet" ;
            lv2:name "Wet" ;
        ] , [
            lv2:index 3 ;
            lv2:symbol "drive" ;
            lv2:name "Drive" ;
        ] ;
    ] .