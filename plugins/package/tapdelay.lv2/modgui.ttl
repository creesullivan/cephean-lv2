@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://github.com/creesullivan/cephean/tapdelay>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-cephean-tap-delay.html> ;
        modgui:stylesheet <modgui/stylesheet-cephean-tap-delay.css> ;
        modgui:screenshot <modgui/screenshot-cephean-tap-delay.png> ;
        modgui:thumbnail <modgui/thumbnail-cephean-tap-delay.png> ;
        modgui:brand "cephean" ;
        modgui:label "Tap Delay" ;
        modgui:model "boxy" ;
        modgui:panel "6-knobs" ;
        modgui:color "darkblue" ;
        modgui:knob "black" ;
        modgui:port [
            lv2:index 0 ;
            lv2:symbol "tempo" ;
            lv2:name "Tempo" ;
        ] , [
            lv2:index 1 ;
            lv2:symbol "feedback" ;
            lv2:name "Feedback" ;
        ] , [
            lv2:index 2 ;
            lv2:symbol "color" ;
            lv2:name "Color" ;
        ] , [
            lv2:index 3 ;
            lv2:symbol "rolloff" ;
            lv2:name "Rolloff" ;
        ] , [
            lv2:index 4 ;
            lv2:symbol "dry" ;
            lv2:name "Dry" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "wet" ;
            lv2:name "Wet" ;
        ] ;
    ] .