@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .
@prefix epp: <http://lv2plug.in/ns/ext/port-props#> .
@prefix mod: <http://moddevices.com/ns/mod#> .

<https://github.com/creesullivan/cephean/reguitar>
	a lv2:Plugin , lv2:EQPlugin ;
	
	lv2:extensionData <http://lv2plug.in/ns/ext/state#interface> ;

    lv2:optionalFeature <http://lv2plug.in/ns/lv2core#hardRTCapable> ,
                        <http://lv2plug.in/ns/ext/buf-size#boundedBlockLength> ;

    lv2:requiredFeature <http://lv2plug.in/ns/ext/options#options> ,
                        <http://lv2plug.in/ns/ext/urid#map> ;
	
	doap:name "Cephean ReGuitar";
	doap:license "ISC";
	doap:maintainer [
        foaf:name "cephean" ;
    ] ;
	
	rdfs:comment """
Cephean guitar pickup character adjustment tool
""" ;
	
	lv2:minorVersion 1 ;
	lv2:microVersion 0 ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 0 ;
		lv2:symbol "freq1" ;
		lv2:name "Freq1" ;
		lv2:default 4000.0 ;
		lv2:minimum 2000.0 ;
		lv2:maximum 8000.0 ;
		lv2:portProperty epp:logarithmic ;
		units:unit units:hz
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 1 ;
		lv2:symbol "res1" ;
		lv2:name "Res1" ;
		lv2:default 0.0 ;
		lv2:minimum -12.0 ;
		lv2:maximum 12.0 ;
		units:unit units:db
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 2 ;
		lv2:symbol "freq2" ;
		lv2:name "Freq2" ;
		lv2:default 4000.0 ;
		lv2:minimum 2000.0 ;
		lv2:maximum 8000.0 ;
		lv2:portProperty epp:logarithmic ;
		units:unit units:hz
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 3 ;
		lv2:symbol "res2" ;
		lv2:name "Res2" ;
		lv2:default 0.0 ;
		lv2:minimum -12.0 ;
		lv2:maximum 12.0 ;
		units:unit units:db
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:index 4 ;
		lv2:symbol "gain" ;
		lv2:name "Gain" ;
		lv2:default 0.0 ;
		lv2:minimum -12.0 ;
		lv2:maximum 12.0 ;
		units:unit units:db
	] ;
	
	lv2:port [
		a lv2:InputPort , lv2:AudioPort ;
		lv2:index 5 ;
		lv2:symbol "in" ;
		lv2:name "In"
	] ;
	
	lv2:port [
		a lv2:OutputPort , lv2:AudioPort ;
		lv2:index 6 ;
		lv2:symbol "out" ;
		lv2:name "Out"
	] .
