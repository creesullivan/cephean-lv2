@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://github.com/creesullivan/cephean/overdrive>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-cephean-overdrive.html> ;
        modgui:stylesheet <modgui/stylesheet-cephean-overdrive.css> ;
        modgui:screenshot <modgui/screenshot-cephean-overdrive.png> ;
        modgui:thumbnail <modgui/thumbnail-cephean-overdrive.png> ;
        modgui:brand "" ;
        modgui:label "CEPHEAN OVERDRIVE" ;
        modgui:model "boxy" ;
        modgui:panel "8-knobs" ;
        modgui:color "darkblue" ;
        modgui:knob "black" ;
        modgui:port [
            lv2:index 0 ;
            lv2:symbol "drive" ;
            lv2:name "Drive" ;
        ] , [
            lv2:index 1 ;
            lv2:symbol "bias" ;
            lv2:name "Bias" ;
        ] , [
            lv2:index 2 ;
            lv2:symbol "gate" ;
            lv2:name "Gate" ;
        ] , [
            lv2:index 3 ;
            lv2:symbol "low" ;
            lv2:name "Low" ;
        ] , [
            lv2:index 4 ;
            lv2:symbol "high" ;
            lv2:name "High" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "tone" ;
            lv2:name "Tone" ;
        ] , [
            lv2:index 6 ;
            lv2:symbol "dry" ;
            lv2:name "Dry" ;
        ] , [
            lv2:index 7 ;
            lv2:symbol "wet" ;
            lv2:name "Wet" ;
        ] ;
    ] .