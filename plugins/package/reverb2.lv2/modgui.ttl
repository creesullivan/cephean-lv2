@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://github.com/creesullivan/cephean/reverb2>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-cephean-reverb-v2.html> ;
        modgui:stylesheet <modgui/stylesheet-cephean-reverb-v2.css> ;
        modgui:screenshot <modgui/screenshot-cephean-reverb-v2.png> ;
        modgui:thumbnail <modgui/thumbnail-cephean-reverb-v2.png> ;
        modgui:brand "cephean" ;
        modgui:label "Reverb 2.0" ;
        modgui:model "boxy" ;
        modgui:panel "6-knobs" ;
        modgui:color "darkblue" ;
        modgui:knob "black" ;
        modgui:port [
            lv2:index 0 ;
            lv2:symbol "tail" ;
            lv2:name "Tail" ;
        ] , [
            lv2:index 1 ;
            lv2:symbol "color" ;
            lv2:name "Color" ;
        ] , [
            lv2:index 2 ;
            lv2:symbol "rolloff" ;
            lv2:name "Rolloff" ;
        ] , [
            lv2:index 3 ;
            lv2:symbol "energy" ;
            lv2:name "Energy" ;
        ] , [
            lv2:index 4 ;
            lv2:symbol "wet" ;
            lv2:name "Wet" ;
        ] , [
            lv2:index 5 ;
            lv2:symbol "dry" ;
            lv2:name "Dry" ;
        ] ;
    ] .